#!/bin/bash
mode=$(echo -e "Bildschirme\nLaptop\nDHL" | dmenu -i -fn "System San Francisco Display")

#Screen mode
if [ "$mode" = "" ]; then
		exit 1
elif [ "$mode" = "Bildschirme" ]; then
        xrandr --output LVDS1 --off
		xrandr --output HDMI2 --auto
		xrandr --output HDMI2 --mode 1920x1080
		xrandr --output HDMI3 --auto
		xrandr --output HDMI3 --left-of HDMI2
		xrandr --output HDMI1 --off

elif [ "$mode" = "Laptop" ]; then
		xrandr --output HDMI3 --off
		xrandr --output HDMI2 --off
		xrandr --output HDMI1 --off
		xrandr --output LVDS1 --auto

elif [ "$mode" = "DHL" ]; then
        xrandr --output LVDS1 --auto
		xrandr --output HDMI2 --off
		xrandr --output HDMI3 --off
		xrandr --output HDMI1 --right-of LVDS1
fi

~/.fehbg 
